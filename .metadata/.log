package medicina;

import java.util.ArrayList;

public class Control {

	private ArrayList<Paciente> listaPacientes;
	private ArrayList<Medico> listaMedicos;


	//TODO gestion de citas , agendar , cancelar, mostrar ....
	
	/**
	 * No se le pasan argumentos porque construye los arrays de Pacientes y Medicos
	 */
	public Control() {

		this.listaPacientes = new ArrayList<Paciente>();
		this.listaMedicos = new ArrayList<Medico>();
	}

	
	public gestionCitas()
	
	
	public ArrayList<Paciente> getListaPacientes() {
		return listaPacientes;
	}



	public void setListaPacientes(ArrayList<Paciente> listaPacientes) {
		this.listaPacientes = listaPacientes;
	}



	public ArrayList<Medico> getListaMedicos() {
		return listaMedicos;
	}



	public void setListaMedicos(ArrayList<Medico> listaMedicos) {
		this.listaMedicos = listaMedicos;
	}



	public boolean pacienteYaRegistrado(Paciente p) {
		return FuncionesAux.buscarPaciente(listaPacientes, p) != -1;
	}


	//Doy por hecho que es un paciente real
	/**
	 * El paciente hay que pasarlo sin ser null
	 * @param Paciente 
	 */
	public void registrarPaciente(Paciente p) {
		if (p == null) {
			System.err.println("ERROR: El paciente es nulo");
			return;
		}
		if (pacienteYaRegistrado(p)) {
			System.err.println("Ese paciente ya esta registrado");
			return;
		}
		this.listaPacientes.add(p);
		System.out.println(p.getNombre()+" ha sido registrado satisfactoriamente.");
		FuncionesAux.ordenamientoPacientes(listaPacientes);

	}

	/**
	 * Elimina al paciente
	 * @param Paciente
	 */
	public void quitarPacientes(Paciente p) {
		int indice = FuncionesAux.buscarPaciente(getListaPacientes(), p);
		if (indice != -1) {
			this.listaPacientes.remove(indice);
			System.out.println("El Paciente "+p.getNombre()+" ha sido eliminado con exito");
		} else {
			System.err.println("No se ha encontrado el paciente.");
		}
		FuncionesAux.ordenamientoPacientes(listaPacientes);
	}

	public boolean medicoYaRegistrado(Medico m) {
		return FuncionesAux.buscarMedico(listaMedicos, m) != -1;
	}

	/**
	 * registra el medico
	 * @param medico m
	 */
	public void registrarMedico(Medico m) {
		if (m == null) {
			System.err.println("ERROR: El medico es nulo");
			return; 
		}
		if (medicoYaRegistrado(m)) {
			System.err.println("ERROR: El medico "+m.getNombre()+" ya ha sido registrado");
			return ;
		}
		this.listaMedicos.add(m);
		System.out.println(m.getNombre() +" ha sido registrado con el numero "+ m.getNumeroMedico());
		FuncionesAux.ordenamientoMedicos(listaMedicos);
	}

	/**
	 * Elimina el medico de la lista
	 * @param medico m
	 */
	public void quitarMedicos(Medico m) {
		if (m!= null) {
			int indice = FuncionesAux.buscarMedico(getListaMedicos(), m);
			if (indice != -1) {
				this.listaMedicos.remove(indice);
			} else {
				System.err.println("No se ha podido eliminar de la lista a "+ m.getNombre());
			}
		}else {
			System.err.println("El elemento es nulo");
		}
		FuncionesAux.ordenamientoMedicos(listaMedicos);
	}



	/**
	 * Muestra los pacientes NO argumentos
	 */
	public void mostrarPacientes() {
		System.out.println("\n-----------Pacientes-----------\n");
		for (Paciente p : this.listaPacientes) {
			System.out.println(p);
		}

	}

	/**
	 * Muestra los medicos NO argumentos
	 */
	public void mostrarMedicos() {
		System.out.println("\n-----------Medicos-----------\n");
		for (Medico m : this.listaMedicos) {
			System.out.println(m);
		}
	}
	/**
	 * Muestra todas las personas registradas
	 * NO argumentos
	 */
	public void mostrarPersonasAsociadas() {
		System.out.println("\n-----------Personas Totales asociadas-----------\n");
		System.out.println("Los pacientes:\n");
		mostrarPacientes();
		System.out.println("\nLos medicos\n");
		mostrarMedicos();
	}



	@Override
	public boolean equals(Object obj) {
		// TODO Auto-generated method stub
		return super.equals(obj);
	}

	@Override
	public String toString() {
		return "Clinica con "+ listaPacientes.size()+ " pacientes"+
	" y " +listaMedicos.size()+" medicos";
	}




}
