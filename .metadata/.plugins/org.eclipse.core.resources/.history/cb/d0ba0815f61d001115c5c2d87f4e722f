	// Para el calculo para saber el medico mas cercano
	public static double distancia(Personas a, Personas b) {
	    double dx = a.getX() - b.getX();
	    double dy = a.getY() - b.getY();
	    return Math.sqrt(dx*dx + dy*dy);
	}

	
	public static Medico medicoMasCercano (ArrayList<Medico> meds, Paciente p) {

		Medico cercano = null;
		double menor = 999999999999.0;
		
		for (int i= 0; i < meds.size(); i++) {
			
			Personas personaMed = (Personas) meds.get(i);
			Personas personaPac = (Personas) p;
			double dist = FuncionesAux.distancia(personaMed, personaPac);
			if (dist> menor) {
				menor  = dist;
				cercano = (Medico) personaMed;
			}
		}
		System.out.println("La distancia mas cercana es "+ menor);
		return cercano;
	}
	
	

	
	
	
	
