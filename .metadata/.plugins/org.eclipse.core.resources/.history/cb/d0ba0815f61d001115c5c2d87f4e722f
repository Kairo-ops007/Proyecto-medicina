	/** En caso de ser nulo el año, mes o dia:
	 *  En ese caso de devolvera LocalDate.EPOCH para ponerlo en constante para el control de errores
	 * @param año
	 * @param mes
	 * @param dia
	 * @return
	 */
	public static LocalDate conversionFecha(String año, String mes, String dia) {
		
		if (año == null ) {
			System.err.println("ERROR: El año no puede ser nulo");
			return LocalDate.EPOCH; 
		}
		if (mes == null) {
			System.err.println("ERROR: El mes no puede ser nulo");
			return LocalDate.EPOCH ; 
		}
		if (dia == null) {
			System.err.println("ERROR: El dia no puede ser nulo");
			return LocalDate.EPOCH ;
		}
		String texto = año +"-"+mes+"-"+dia;
		
		return LocalDate.parse(texto);
	}
	
	
	
