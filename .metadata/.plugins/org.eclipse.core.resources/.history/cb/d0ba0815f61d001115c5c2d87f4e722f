	public static void mostrarMedicoMasAntiguo (ArrayList<Medico> meds) {
		if (meds == null) {
			System.err.println("ERROR: La lista de medicos está vacía");
			return; 
		}
		Medico med = null;
		int mayor = -1;
		for (int i = 0; i < meds.size(); i++) {
			if (meds.get(i).getCont() > mayor ) {
				mayor = meds.get(i).getCont();
				med = meds.get(i);
			}
		}
		System.out.println("El medico mas antiguo de la clinica es "+ med);
		
	}
	
