	 */
	public boolean esMenor() {
		return this.getEdad()< 18;
	}

	/**
	 * Devuelve si el paciente es mayor de edad
	 * @return
	 */
	public boolean esMayor() {
		return !esMenor();
	}

	@Override
	public boolean equals(Object obj) {

