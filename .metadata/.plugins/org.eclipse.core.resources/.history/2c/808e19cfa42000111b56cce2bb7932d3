	/**
	 * Diagnostico de el indice de la masa corporal de un paciente
	 * @return
	 */
	public String diagnosticoImc () {
		double calculo = imc();
		if (calculo < 18.5) {
			return "El peso es inferior a lo normal";
		} else if(18.5 <= calculo && calculo <25){
			return "Normal";
		} else if (25 <= calculo && calculo < 30) {
			return ("Peso superior a lo normal");
		} else {
			return ("¡¡OBESIDAD!!");
		}
	}
	/**
	 * El calculo de el indice de la masa corporal de un paciente
	 * @return
	 */
	public double imc() {
		double calculo = (this.peso) / (this.altura*this.altura);
		return calculo;
	}

	/**
	 * Devuelve si el paciente es menor de edad
