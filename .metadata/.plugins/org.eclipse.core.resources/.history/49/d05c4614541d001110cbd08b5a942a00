	}


	public static boolean comprobacionDNI(Paciente p) {
		String dni = p.getDni().toUpperCase();
		String posible = dni.substring(0,8);
		char letra_pos = dni.charAt(8);
		int op1 = Integer.parseInt(posible);
		String lista_text = "TRWAGMYFPDXBNJZSQVHLCKE";
		int resto = op1 % 23;
		char l_calculada = lista_text.charAt(resto);
		return l_calculada == letra_pos;
		
		
	}
	
	// Para el calculo para saber el medico mas cercano
	public static double distancia(Personas a, Personas b) {
	    double dx = a.getX() - b.getX();
	    double dy = a.getY() - b.getY();
	    return Math.sqrt(dx*dx + dy*dy);
	}

	public static int buscarPaciente (ArrayList<Paciente> array , Paciente p) {
		if (p != null && array != null) {
			for (int i = 0; i <array.size(); i++ ) {
				if (array.get(i).getDni().equals(p.getDni())) {
					return i;
				}
			}
			return -1;
		} else {
			System.err.println("El array es Nulo o la Persona es nula");
			return -1;
		}
	}
	
