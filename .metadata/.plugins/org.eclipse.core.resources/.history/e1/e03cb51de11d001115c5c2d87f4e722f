		if (obj == null ||  !(obj instanceof Personas)) {
			return false;
		}
		
		
		
		
		return super.equals(obj);
	}


	@Override
	public String toString() {
		// TODO Auto-generated method stub
		return super.toString()+"IMC: "+diagnosticoImc()+"\n"+ "Peso: "+peso+"\n"+"Altura: "+altura+"\n" ;
	}


}
