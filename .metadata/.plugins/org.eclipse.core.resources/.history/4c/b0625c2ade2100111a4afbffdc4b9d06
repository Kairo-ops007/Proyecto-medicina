	/**
	 * Ordena la lista de Pacientes
	 * @param array
	 */
	public static void ordenamientoPacientesEdad(ArrayList<Paciente> array) {

		int n = array.size();
		for (int i=0 ; i< n-1; i++ ) {
			for (int j = i+1; j<n; j++ ) {
				if (array.get(i).getEdad() > array.get(j).getEdad()) {
					Paciente temp = array.get(i);
					array.set(i, array.get(j));
					array.set(j, temp);
				}
			}
		}
	}
	
	
