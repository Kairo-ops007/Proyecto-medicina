	public ArrayList<Medico> medicosEspecialistasEn(Tipo_medico tm){
		ArrayList<Medico> listaMedicos = new ArrayList<Medico>();

		for (Medico m : getListaMedicos()) {
			for (Tipo_medico tipo : m.getEspecialidades()) {
				if (tm != null && tipo!= null &&tm.equals(tipo)) {
					listaMedicos.add(m);
				}
			}
		}
		return listaMedicos;
	}

	
	public ArrayList<Paciente> buscarPacientesObesos(){
		ArrayList<Paciente> listaPacientes = new ArrayList<Paciente>();

		for (Paciente p : getListaPacientes()) {
			if (p.imc()> 30) {
				listaPacientes.add(p);
			}
		}

		return listaPacientes;
	}


	public ArrayList<Paciente> buscarPacientesBajoPeso(){
		ArrayList<Paciente> listaPacientes = new ArrayList<Paciente>();

		for (Paciente p: getListaPacientes()) {
			if (p.imc() < 18.5) {
				listaPacientes.add(p);
			}
		}

		return listaPacientes;
	}

	public void atenderCita(Cita c, String Diagnostico, String medicamento) {

		if (c == null) {
			System.err.println("ERROR: La cita no puede ser nula");
		}

		if (c.isAtendida()) {
			System.err.println("ERROR: La cita ya ha sido atendida");
			return; 
		}

		c.setAtendida(true);




		if (!Diagnostico.isEmpty() && Diagnostico != null) {

			if (!medicamento.isEmpty() && medicamento != null) {

				Paciente p = c.getPaciente();
				p.getHistorial().agregarEnfermedad(Diagnostico);
				p.getHistorial().agregarMedicamentos(medicamento);

			} else {

				System.err.println("ERROR: El medicamento no puede ser nulo");
			}

		} else {

			System.err.println("ERROR: El diagnostico no puede ser nulo");
		}

	}



	public void porcentajeMenores(ArrayList<Paciente> pacs) {
		
		if (pacs.size() == 0) {
			System.err.println("ADVERTENCIA: La lista de pacientes está vacía");
			return; 
		}
		
		int cont = 0;
		for (Paciente p : pacs) {
			if (p != null) {
				if (p.esMenor()) {
					cont ++;
				}
			}else {
				System.err.println("ERROR: El paciente no pude ser nulo");
			}
		}
		double calculo = cont/pacs.size() *100;
		System.out.println("El porcentaje de menores entre los pacientes es: "+ calculo);
		
	}
	
