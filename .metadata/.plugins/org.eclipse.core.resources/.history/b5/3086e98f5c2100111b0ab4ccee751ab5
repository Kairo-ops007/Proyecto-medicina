	/**
	 * Asigna una cita al paciente y al medico con un motivo
	 * @param p
	 * @param m
	 * @param motivo
	 */
	public void agendar(Paciente p , Medico m, String motivo) {

		Cita cita = new Cita (p, m, LocalDate.now(), LocalTime.NOON, motivo, false );
		p.getCitas().add(cita);

	}

	/**
	 * Cancela la cita para un paciente y un medico
