	 * @param c
	 */
	public void cancelarCita(Paciente p, Cita c) {

		int indice = FuncionesAux.buscarCitas(p.getCitas(), c);
		if (indice != -1) {
			p.getCitas().remove(indice);
		} else {
			System.err.println("ERROR: No se ha encontrado la cita");
		}
	}
